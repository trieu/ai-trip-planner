# AI Trip Planner - API Server Configuration
HOST=0.0.0.0
PORT=8000
FRONTEND_DIR=../frontend

# --- Feature Flags ---
# Toggle Retrieval-Augmented Generation features (1 for true, 0 for false)
ENABLE_RAG=1

# --- LLM Provider Selection ---
# Options: GOOGLE_GEMINI | OPENAI
LLM_PROVIDER=OPENAI

# --- Model Configuration ---

# For GOOGLE_GEMINI: gemini-2.5-flash-lite, models/text-embedding-004
# For OPENAI: gpt-5.4-mini, text-embedding-3-small
LLM_MODEL_NAME=gpt-5.4-mini
EMBEDDING_MODEL_NAME=text-embedding-3-small

# --- API Keys ---
GOOGLE_GEMINI_API_KEY=your_google_key
OPENAI_API_KEY=your_openai_key

# Optional: Tavily API Key for enhanced itinerary generation (if you have access)
TAVILY_API_KEY=

# ==========================================
# Profile Source Config
# ==========================================
# Options: LEO_CDP | POSTGRES | MOCK_DATA
PROFILE_SOURCE=MOCK_DATA

# ==========================================
# LEO CDP Config for user profile retrieval (if you switch source)
# ==========================================
LEO_API_KEY=
LEO_API_VALUE=
LEO_BASE_URL=

# ==========================================
# Optional: Postgres (if you switch source)
# ==========================================
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# --- Observability & Tracing ---
# The endpoint where Phoenix/OpenTelemetry collects trace data
PHOENIX_COLLECTOR_ENDPOINT='http://localhost:6006/v1/traces'


# SSO Config (if you implement authentication)
# SSO_PROVIDER=GOOGLE | FACEBOOK | OAUTH
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET= 
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=