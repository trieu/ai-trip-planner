# ========================================
# Server Configuration
# ========================================
HOST=0.0.0.0
PORT=8000
WORKERS=4
FRONTEND_DIR=../frontend
ENVIRONMENT=production

# ========================================
# JWT Authentication
# ========================================
JWT_SECRET=your-super-secret-key-at-least-32-characters-long-change-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# ========================================
# Feature Flags
# ========================================
ENABLE_RAG=1
ENABLE_CACHING=1
ENABLE_TELEMETRY=1
ENABLE_PERSONA_REPORTS=1

# ========================================
# LLM Provider
# ========================================
LLM_PROVIDER=OPENAI
LLM_MODEL_NAME=gpt-4o-mini
EMBEDDING_MODEL_NAME=text-embedding-3-small
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_REQUEST_TIMEOUT=30

# ========================================
# API Keys
# ========================================
OPENAI_API_KEY=sk-your-openai-key-here
GOOGLE_GEMINI_API_KEY=your-google-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
TAVILY_API_KEY=your-tavily-key-here

# ========================================
# Profile Source
# ========================================
PROFILE_SOURCE=MOCK_DATA

# ========================================
# LEO CDP (if using)
# ========================================
LEO_API_KEY=
LEO_API_VALUE=
LEO_BASE_URL=

# ========================================
# PostgreSQL (if using)
# ========================================
PGSQL_DB_HOST=localhost
PGSQL_DB_PORT=5432
PGSQL_DB_NAME=trip_planner
PGSQL_DB_USER=postgres
PGSQL_DB_PASSWORD=

# ========================================
# Redis Cache
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_TTL=3600

# ========================================
# Observability
# ========================================
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
OTEL_SERVICE_NAME=ai-trip-planner-api
OTEL_EXPORTER_OTLP_TIMEOUT=10

# ========================================
# SSO (Optional)
# ========================================
SSO_PROVIDER=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ========================================
# CORS Configuration
# ========================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true

# ========================================
# Logging
# ========================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ========================================
# Data Directories
# ========================================
PERSONA_DATA_DIR=data/personas
REPORTS_DATA_DIR=data/reports
TEMPLATES_DIR=data/templates
MAX_REPORT_SIZE_MB=10