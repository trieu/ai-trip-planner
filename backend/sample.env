# AI Trip Planner - Environment Configuration

# --- Feature Flags ---
# Toggle Retrieval-Augmented Generation features (1 for true, 0 for false)
ENABLE_RAG=0

# --- Model Configuration ---
EMBEDDING_MODEL_NAME=models/text-embedding-004
LLM_MODEL_NAME=gemini-2.5-flash-lite

# ==========================================
# Core API Keys
# ==========================================

# Your OpenAI API Key for the main LLM and Embeddings
OPENAI_API_KEY=

# Your Google Gemini API Key for the main LLM and Embeddings
GOOGLE_GEMINI_API_KEY=

# Optional: Tavily API Key for enhanced itinerary generation (if you have access)
TAVILY_API_KEY=

# ==========================================
# Profile Source Config
# ==========================================
# Options: LEO_CDP | POSTGRES | MOCK_DATA
PROFILE_SOURCE=MOCK_DATA

# ==========================================
# LEO CDP Config
# ==========================================
LEO_API_KEY=
LEO_API_VALUE=
LEO_BASE_URL=

# ==========================================
# Optional: Postgres (if you switch source)
# ==========================================
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=


# --- Observability & Tracing ---
# The endpoint where Phoenix/OpenTelemetry collects trace data
PHOENIX_COLLECTOR_ENDPOINT="http://localhost:6006/v1/traces"